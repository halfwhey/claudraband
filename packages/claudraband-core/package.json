{
  "name": "@halfwhey/claudraband-core",
  "version": "0.6.0",
  "description": "TypeScript runtime for controlling local Claude Code sessions through a real terminal.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun build src/index.ts --target node --packages external --outdir dist",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "prepack": "bun run build",
    "test": "bun test src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.96",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "tmux",
    "session"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halfwhey/claudraband",
    "directory": "packages/claudraband-core"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^24.6.0",
    "typescript": "^5.8.0"
  }
}
