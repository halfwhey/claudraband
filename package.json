{
  "name": "claudraband-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter claudraband-core build && bun run --filter claudraband build",
    "test": "bun test packages/claudraband-core/src packages/claudraband-cli/src",
    "typecheck": "tsc -b packages/claudraband-core packages/claudraband-cli"
  }
}
